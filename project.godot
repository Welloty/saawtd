; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="saawtd"
run/main_scene="res://loading/control.tscn"
config/features=PackedStringArray("4.7", "GL Compatibility")
config/icon="res://loading/icon.svg"

[autoload]

SettingsManager="*res://settings_manager.gd"
Global="*uid://bvvb3ymjcjkru"

[display]

window/size/mode=2
window/stretch/mode="canvas_items"
window/stretch/aspect="ignore"

[internationalization]

locale/translations=PackedStringArray("res://locale/translations.en.translation", "res://locale/translations.ru.translation")

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

rendering_device/driver.windows="d3d12"
renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
textures/vram_compression/import_etc2_astc=true
